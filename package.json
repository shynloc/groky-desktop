{
  "name": "groky",
  "version": "0.1.0",
  "description": "Groky — Desktop GUI client for Grok Build (xAI Grok CLI)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:check": "node -e \"try{require('child_process').execSync('cargo --version',{stdio:'ignore'})}catch(e){console.error('Rust/Cargo not found in PATH. Run: source \\\"$HOME/.cargo/env\\\" or restart terminal.');process.exit(1)}\" && tauri dev",
    "tauri:build": "tauri build",
    "start": "npm run tauri:dev",
    "postinstall": "echo '如果需要，可手动运行: source \"$HOME/.cargo/env\"'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
